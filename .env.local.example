# Supabase — nađi na: supabase.com → tvoj projekat → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Google Maps — opciono, samo za CourtMapEmbed na stranici pojedinačnog terena.
# Ako izostaviš, prikazuje se elegantan fallback bez mape (aplikacija radi normalno).
# nađi na: console.cloud.google.com → APIs & Services → Maps Embed API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Supabase Service Role — NIKAD ne commitovati, samo za server-side (API routes)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
